{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs",
		"test": "vitest",
		"test:run": "vitest run"
	},
	"dependencies": {
		"@ai-sdk/devtools": "^0.0.2",
		"@ai-sdk/google": "^3.0.1",
		"@colorir/auth": "workspace:*",
		"@colorir/db": "workspace:*",
		"@colorir/env": "workspace:*",
		"@colorir/storage": "workspace:*",
		"ai": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.8.2",
		"pdf-lib": "^1.17.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@colorir/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.21.9",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"@vitest/coverage-v8": "catalog:"
	}
}
