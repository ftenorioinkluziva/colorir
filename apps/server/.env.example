# ============================================
# Server Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# Database
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/colorir

# Authentication secret
# Generate with: openssl rand -hex 32
# Or: bun -e "console.log(crypto.randomBytes(32).toString('hex'))"
# Minimum 32 characters
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# Base URL for the server (used for auth callbacks)
BETTER_AUTH_URL=http://localhost:3000

# CORS origin — frontend application URL
CORS_ORIGIN=http://localhost:3001

# Google Generative AI (Gemini) — for AI features
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Environment
# Options: development, production, test
NODE_ENV=development

# Skip env validation on startup (opt-in for Docker/CI)
# SKIP_ENV_VALIDATION=true
